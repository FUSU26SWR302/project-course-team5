# Frontend environment (copy to .env — do not commit .env)
VITE_API_BASE_URL=http://localhost:5001/api

# Google OAuth Web Client ID
# Authorized JavaScript origins (no trailing slash, no /login, no /api):
#   http://localhost:5173
#   http://localhost:5174
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
